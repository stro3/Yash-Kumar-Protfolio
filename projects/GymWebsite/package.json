{
  "name": "gym-website",
  "version": "1.0.0",
  "description": "Comprehensive Gym Website with React Frontend and Node.js Backend",
  "scripts": {
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && node server.js",
    "install:all": "cd frontend && npm install && cd ../backend && npm install",
    "build": "cd frontend && npm run build",
    "start:prod": "cd backend && npm start"
  },
  "devDependencies": {
    "@express-rate-limit/tsconfig": "^1.0.2",
    "concurrently": "^8.2.2",
    "tailwindcss": "^3.4.17"
  },
  "keywords": [
    "gym",
    "fitness",
    "react",
    "nodejs",
    "express",
    "mongodb"
  ],
  "author": "Gym Website Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.11.0"
  }
}
